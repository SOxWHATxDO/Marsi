<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Карта -->
    <com.yandex.mapkit.mapview.MapView
        android:id="@+id/mapview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Кнопка меню (увеличена) -->
    <ImageView
        android:id="@+id/iv_menu_icon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="0dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:src="@drawable/ic_menu" />

    <!-- Окно времени (значительно уменьшено) -->
    <TextView
        android:id="@+id/tvEta"
        android:layout_width="60dp"
        android:layout_height="20dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="@drawable/ic_time"
        android:gravity="center"
        android:padding="2dp"
        android:text=""
        android:textColor="@android:color/black"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Статус курьера удалён, логирование перенесено в код -->

    <!-- Кнопка «Построить маршрут» слева над нижней панелью (приподнята) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabBuildRoute"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="88dp"
        android:src="@android:drawable/ic_menu_directions"
        android:contentDescription="Построить маршрут"
        app:layout_anchor="@id/bottom_sheet"
        app:layout_anchorGravity="top|start" />

    <!-- Кнопка «Фокус» справа над нижней панелью (приподнята) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabFocusLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="88dp"
        android:contentDescription="Фокус на моём местоположении"
        android:src="@android:drawable/ic_menu_mylocation"
        app:layout_anchor="@id/bottom_sheet"
        app:layout_anchorGravity="top|end" />

    <!-- Нижняя панель с кнопками -->
    <RelativeLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_low_bar"
        android:elevation="16dp"
        android:padding="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="false"
        app:behavior_peekHeight="80dp"
        app:behavior_expandedOffset="200dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTransport"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Транспорт"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChat"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Чат"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteOrder"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Заказ"
                android:textSize="12sp"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Оверлей чата -->
    <FrameLayout
        android:id="@+id/chat_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="32dp"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Чат с клиентом (заглушка)"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="100dp"
                android:text="Здесь могла бы быть переписка." />

            <Button
                android:id="@+id/btnCloseChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="16dp"
                android:text="Закрыть" />
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>