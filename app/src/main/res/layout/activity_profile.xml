<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Иванов Иван"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Календарь смен:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCalendar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[заглушка календаря]" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Статистика:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatsWeek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Часы за неделю: 40" />

        <TextView
            android:id="@+id/tvStatsMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Часы за месяц: 160" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Привязанный ЦФЗ:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ул. Ленина, 5 (заглушка)" />
    </LinearLayout>
</ScrollView>